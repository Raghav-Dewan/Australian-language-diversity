{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 360,
  "title": {
    "text": "Australia's Top 10 Non-English Languages (2021)",
    "subtitle": "Mandarin leads with 685 k speakers. Punjabi surged past Greek and Italian.",
    "anchor": "start",
    "color": "#ffffff",
    "fontSize": 18,
    "subtitleFontSize": 12,
    "subtitleColor": "rgba(226,232,240,0.78)",
    "offset": 12
  },
  "data": {
    "url": "data/top_languages_australia.csv"
  },
  "layer": [
    {
      "mark": {
        "type": "rule",
        "strokeWidth": 2.5,
        "opacity": 0.32
      },
      "encoding": {
        "y": {
          "field": "language",
          "type": "nominal",
          "sort": {
            "field": "speakers_2021",
            "order": "descending"
          }
        },
        "x": {
          "datum": 0,
          "type": "quantitative"
        },
        "x2": {
          "field": "speakers_2021",
          "type": "quantitative"
        },
        "color": {
          "condition": {
            "test": "datum.change_pct > 0",
            "value": "#f94144"
          },
          "value": "#4d96ff"
        }
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 200
      },
      "encoding": {
        "y": {
          "field": "language",
          "type": "nominal",
          "sort": {
            "field": "speakers_2021",
            "order": "descending"
          },
          "title": null,
          "axis": {
            "labelFontSize": 12,
            "labelColor": "#e2e8f0",
            "labelFontWeight": "bold"
          }
        },
        "x": {
          "field": "speakers_2021",
          "type": "quantitative",
          "title": "Speakers in 2021",
          "axis": {
            "format": ".2s",
            "grid": true,
            "gridDash": [
              3,
              3
            ],
            "gridColor": "rgba(226,232,240,0.13)",
            "labelColor": "#e2e8f0",
            "titleColor": "#e2e8f0"
          }
        },
        "color": {
          "condition": {
            "test": "datum.change_pct > 0",
            "value": "#f94144"
          },
          "value": "#4d96ff"
        },
        "tooltip": [
          {
            "field": "language",
            "type": "nominal",
            "title": "Language"
          },
          {
            "field": "speakers_2021",
            "type": "quantitative",
            "title": "Speakers (2021)",
            "format": ","
          },
          {
            "field": "speakers_2016",
            "type": "quantitative",
            "title": "Speakers (2016)",
            "format": ","
          },
          {
            "field": "change_pct",
            "type": "quantitative",
            "title": "Change 2016–2021 (%)",
            "format": "+.1f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 9,
        "fontSize": 10.5
      },
      "encoding": {
        "y": {
          "field": "language",
          "type": "nominal",
          "sort": {
            "field": "speakers_2021",
            "order": "descending"
          }
        },
        "x": {
          "field": "speakers_2021",
          "type": "quantitative"
        },
        "text": {
          "field": "speakers_2021",
          "type": "quantitative",
          "format": ",.0f"
        },
        "color": {
          "value": "rgba(226,232,240,0.65)"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    }
  },
  "autosize": {
    "type": "fit",
    "contains": "padding",
    "resize": true
  },
  "background": "rgba(0,0,0,0)"
}